:root {
  --bg:      #07070F;
  --surface: #0F0F1C;
  --card:    #16162A;
  --border:  #25253A;
  --text:    #E6E6F0;
  --muted:   #5A5A7A;
  --t0:  #6B7280;
  --t1:  #3B82F6;
  --t15: #A855F7;
  --t2:  #F59E0B;
  --gold: #FFB800;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Barlow', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── HEADER ── */
header {
  text-align: center;
  padding: 52px 20px 36px;
  background: linear-gradient(180deg, #0E0E28 0%, var(--bg) 100%);
  border-bottom: 1px solid var(--border);
}
.logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.8rem, 8vw, 5rem);
  letter-spacing: 0.1em;
  background: linear-gradient(130deg, #FFB800 20%, #FF5500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}
.tagline {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.85rem;
  letter-spacing: 0.35em;
  color: var(--muted);
  text-transform: uppercase;
  margin-top: 6px;
}

/* ── FILTERS ── */
.filters {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8px;
  padding: 28px 20px;
}
.filter-btn {
  padding: 7px 18px;
  border-radius: 4px;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--muted);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.88rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  cursor: pointer;
  transition: all 0.15s;
  text-transform: uppercase;
}
.filter-btn:hover { color: var(--text); border-color: #44445A; }
.filter-btn.active { color: #050508; border-color: transparent; }
.filter-btn[data-tier="all"].active  { background: var(--text); }
.filter-btn[data-tier="t0"].active   { background: var(--t0); }
.filter-btn[data-tier="t1"].active   { background: var(--t1); }
.filter-btn[data-tier="t15"].active  { background: var(--t15); }
.filter-btn[data-tier="t2"].active   { background: var(--t2); }

/* ── WHEEL ── */
.wheel-wrap {
  position: relative;
  width: 100%;
  height: 130px;
  overflow: hidden;
  background: var(--surface);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}
/* golden selector box at center */
.wheel-selector {
  position: absolute;
  top: 8px;
  bottom: 8px;
  left: 50%;
  width: 124px;
  transform: translateX(-50%);
  border: 2px solid var(--gold);
  border-radius: 7px;
  box-shadow: 0 0 24px rgba(255,184,0,0.35), inset 0 0 12px rgba(255,184,0,0.06);
  pointer-events: none;
  z-index: 10;
}
/* edge fades */
.wheel-fade {
  position: absolute;
  top: 0; bottom: 0;
  width: 140px;
  z-index: 5;
  pointer-events: none;
}
.wheel-fade.left  { left:  0; background: linear-gradient(90deg, var(--surface) 20%, transparent); }
.wheel-fade.right { right: 0; background: linear-gradient(270deg, var(--surface) 20%, transparent); }

.wheel-strip {
  display: flex;
  align-items: center;
  height: 100%;
  gap: 8px;
  padding-left: 8px;
  will-change: transform;
  transform: translateX(0);
}
.wcard {
  flex-shrink: 0;
  width: 116px;
  height: 106px;
  border-radius: 7px;
  background: var(--card);
  border: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8px;
  text-align: center;
  gap: 6px;
}
.wcard.winner {
  border-color: var(--gold) !important;
  box-shadow: 0 0 16px rgba(255,184,0,0.25);
}
.wcard .badge {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: 3px;
}
.wcard .gname {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--text);
  line-height: 1.25;
}

/* ── SPIN BUTTON ── */
.controls {
  display: flex;
  justify-content: center;
  padding: 24px 20px 8px;
}
.spin-btn {
  padding: 13px 64px;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.7rem;
  letter-spacing: 0.18em;
  border: none;
  border-radius: 6px;
  background: linear-gradient(130deg, #FFB800 0%, #FF5500 100%);
  color: #05050A;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 4px 24px rgba(255,184,0,0.28);
}
.spin-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(255,184,0,0.42);
}
.spin-btn:active:not(:disabled) { transform: translateY(0); }
.spin-btn:disabled { opacity: 0.45; cursor: not-allowed; transform: none; box-shadow: none; }

/* ── RESULT ── */
.result-wrap {
  max-width: 520px;
  margin: 20px auto 0;
  padding: 0 20px;
}
.result-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 28px 24px;
  min-height: 110px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.4s ease, transform 0.4s ease;
}
.result-card.show { opacity: 1; transform: translateY(0); }
.result-tier-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.result-gun-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(1.8rem, 5vw, 2.6rem);
  letter-spacing: 0.06em;
  line-height: 1;
}
.result-placeholder {
  color: var(--muted);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.95rem;
  letter-spacing: 0.1em;
}

/* ── DIVIDER ── */
.divider {
  max-width: 860px;
  margin: 36px auto 0;
  padding: 0 20px;
  border: none;
  border-top: 1px solid var(--border);
}
.section-label {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.28em;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 14px;
}

/* ── HISTORY ── */
.history-wrap {
  max-width: 580px;
  margin: 28px auto 0;
  padding: 0 20px;
  display: none;
}
.history-list { display: flex; flex-direction: column; gap: 6px; }
.history-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
}
.history-gun {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.98rem;
  font-weight: 600;
}
.history-badge {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  padding: 3px 9px;
  border-radius: 3px;
}

/* ── BROWSE ── */
.browse-wrap {
  max-width: 860px;
  margin: 32px auto 64px;
  padding: 0 20px;
}
.tier-block { margin-bottom: 30px; }
.tier-block-header {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin-bottom: 12px;
}
.tier-block-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.45rem;
  letter-spacing: 0.06em;
}
.tier-block-sub {
  font-size: 0.8rem;
  color: var(--muted);
}
.pills { display: flex; flex-wrap: wrap; gap: 8px; }
.pill {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 0.84rem;
  font-weight: 500;
  border: 1px solid;
  cursor: default;
  transition: transform 0.1s;
}
.pill:hover { transform: scale(1.04); }
.pill.t0  { background: rgba(107,114,128,0.1); border-color: rgba(107,114,128,0.3); color: #9CA3AF; }
.pill.t1  { background: rgba(59,130,246,0.1);  border-color: rgba(59,130,246,0.3);  color: #60A5FA; }
.pill.t15 { background: rgba(168,85,247,0.1);  border-color: rgba(168,85,247,0.3);  color: #C084FC; }
.pill.t2  { background: rgba(245,158,11,0.1);  border-color: rgba(245,158,11,0.3);  color: #FCD34D; }

/* tier badge color map */
.badge.t0  { background: rgba(107,114,128,0.2); color: #9CA3AF; }
.badge.t1  { background: rgba(59,130,246,0.2);  color: #60A5FA; }
.badge.t15 { background: rgba(168,85,247,0.2);  color: #C084FC; }
.badge.t2  { background: rgba(245,158,11,0.2);  color: #FCD34D; }

@media (max-width: 520px) {
  .spin-btn { padding: 12px 40px; font-size: 1.4rem; }
  .wheel-fade { width: 80px; }
}
