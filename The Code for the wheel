<body>

<!-- HEADER -->

<header>
  <div class="logo">The Raq RP</div>
  <div class="tagline">Weapon Wheelspin</div>
</header>

<!-- FILTERS -->

<div class="filters">
  <button class="filter-btn active" data-tier="all">All Tiers</button>
  <button class="filter-btn" data-tier="t0">🚶 Tier 0</button>
  <button class="filter-btn" data-tier="t1">🔫 Tier 1</button>
  <button class="filter-btn" data-tier="t15">⚡ Tier 1.5</button>
  <button class="filter-btn" data-tier="t2">💎 Tier 2</button>
</div>

<!-- WHEEL -->

<div class="wheel-wrap">
  <div class="wheel-selector"></div>
  <div class="wheel-fade left"></div>
  <div class="wheel-fade right"></div>
  <div class="wheel-strip" id="strip"></div>
</div>

<!-- SPIN BTN -->

<div class="controls">
  <button class="spin-btn" id="spinBtn">SPIN</button>
</div>

<!-- RESULT -->

<div class="result-wrap">
  <div class="result-card" id="resultCard">
    <span class="result-placeholder">Hit SPIN to receive your weapon</span>
  </div>
</div>

<!-- HISTORY -->

<div class="history-wrap" id="historyWrap">
  <hr class="divider" style="margin:0 0 20px;" />
  <div class="section-label">Recent Spins</div>
  <div class="history-list" id="historyList"></div>
</div>

<!-- BROWSE -->

<div class="browse-wrap">
  <hr class="divider" style="margin:0 0 24px;" />
  <div class="section-label">All Weapons</div>
  <div id="browseGrid"></div>
</div>

<script>
  /* ── DATA ── */
  const TIERS = {
    t0: {
      name: 'Tier 0', emoji: '🚶', label: 'Basic Handguns',
      color: '#6B7280',
      guns: ['Barretta','P320','1911','G2C','Walther','Hi-Point']
    },
    t1: {
      name: 'Tier 1', emoji: '🔫', label: 'Standard Sidearms',
      color: '#3B82F6',
      guns: ['G17','Five-Seven','XD Compact','G27']
    },
    t15: {
      name: 'Tier 1.5', emoji: '⚡️', label: 'Modified Sidearms',
      color: '#A855F7',
      guns: ['G17 (Extended Mag)','Five-Seven (Laser)','G17 (Flashlight / Tan Slide)','Glock 19 (Taran Tactical)','Glock 26 Binary']
    },
    t2: {
      name: 'Tier 2', emoji: '💎', label: 'Advanced / Automatic',
      color: '#F59E0B',
      guns: ['Glock 17 (Switch / Extended)','MPX','Draco','ARP','Glock Switch','Kriss Vector']
    }
  };

  /* card width (116px) + gap (8px) = 124px per slot */
  const SLOT_W     = 124;
  const WIN_IDX    = 50;   /* winner will land at this position in the strip */
  const STRIP_LEN  = 65;

  let activeTiers = ['t0','t1','t15','t2'];
  let spinning    = false;
  let history     = [];

  /* ── HELPERS ── */
  function buildPool() {
    const pool = [];
    activeTiers.forEach(t => TIERS[t].guns.forEach(g => pool.push({ gun: g, tier: t })));
    return pool;
  }

  function randFrom(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

  function makeCard(item, winner = false) {
    const tier = TIERS[item.tier];
    const div  = document.createElement('div');
    div.className = 'wcard' + (winner ? ' winner' : '');
    div.style.borderColor = winner ? tier.color : '';
    div.innerHTML = `
      <span class="badge ${item.tier}">${tier.name}</span>
      <span class="gname">${item.gun}</span>`;
    return div;
  }

  /* ── INIT STRIP (idle state) ── */
  function initStrip() {
    const strip = document.getElementById('strip');
    strip.innerHTML = '';
    strip.style.transition = 'none';
    strip.style.transform  = 'translateX(0)';
    const pool = buildPool();
    for (let i = 0; i < 9; i++) strip.appendChild(makeCard(randFrom(pool)));
  }

  /* ── SPIN ── */
  function spin() {
    if (spinning) return;
    const pool = buildPool();
    if (!pool.length) return;

    spinning = true;
    document.getElementById('spinBtn').disabled = true;

    /* hide old result */
    const rc = document.getElementById('resultCard');
    rc.classList.remove('show');

    const winner = randFrom(pool);

    /* build strip array */
    const items = [];
    for (let i = 0; i < STRIP_LEN; i++) items.push(randFrom(pool));
    items[WIN_IDX] = winner;

    /* render */
    const strip = document.getElementById('strip');
    strip.innerHTML    = '';
    strip.style.transition = 'none';
    strip.style.transform  = 'translateX(0)';
    items.forEach((item, i) => strip.appendChild(makeCard(item, i === WIN_IDX)));

    void strip.offsetWidth; /* force reflow */

    /* calculate target so WIN_IDX card is behind the selector */
    const containerW  = strip.parentElement.offsetWidth;
    const selectorCX  = containerW / 2;          /* center x of selector */
    /* card's own center in the strip (at translateX=0):
       left = 8 (padding) + idx * SLOT_W, center = left + 58 (half of 116px) */
    const cardCX = 8 + WIN_IDX * SLOT_W + 58;
    const targetX = selectorCX - cardCX;

    strip.style.transition = 'transform 5.8s cubic-bezier(0.07, 0, 0.04, 1)';
    strip.style.transform  = `translateX(${targetX}px)`;

    setTimeout(() => showResult(winner), 6100);
  }

  function showResult(winner) {
    const tier = TIERS[winner.tier];
    const rc   = document.getElementById('resultCard');
    rc.innerHTML = `
      <div class="result-tier-label" style="color:${tier.color}">${tier.emoji} ${tier.name} — ${tier.label}</div>
      <div class="result-gun-name"  style="color:${tier.color}">${winner.gun}</div>`;
    rc.style.borderColor = tier.color + '55';
    rc.style.boxShadow   = `0 0 32px ${tier.color}1A`;
    void rc.offsetWidth;
    rc.classList.add('show');

    addHistory(winner);
    spinning = false;
    document.getElementById('spinBtn').disabled = false;
  }

  function addHistory(winner) {
    history.unshift(winner);
    if (history.length > 10) history.pop();

    const wrap = document.getElementById('historyWrap');
    const list = document.getElementById('historyList');
    wrap.style.display = 'block';
    list.innerHTML = history.map(item => {
      const t = TIERS[item.tier];
      return `<div class="history-row">
        <span class="history-gun">${item.gun}</span>
        <span class="history-badge" style="color:${t.color};background:${t.color}22">${t.name}</span>
      </div>`;
    }).join('');
  }

  /* ── FILTER BUTTONS ── */
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const t = btn.dataset.tier;
      const allBtn = document.querySelector('[data-tier="all"]');

      if (t === 'all') {
        activeTiers = ['t0','t1','t15','t2'];
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        allBtn.classList.add('active');
      } else {
        allBtn.classList.remove('active');
        if (activeTiers.includes(t)) {
          if (activeTiers.length === 1) return;
          activeTiers = activeTiers.filter(x => x !== t);
          btn.classList.remove('active');
        } else {
          activeTiers.push(t);
          btn.classList.add('active');
        }
        if (activeTiers.length === 4) allBtn.classList.add('active');
      }
      initStrip();
    });
  });

  document.getElementById('spinBtn').addEventListener('click', spin);

  /* ── BROWSE GRID ── */
  function renderBrowse() {
    document.getElementById('browseGrid').innerHTML = Object.entries(TIERS).map(([key, tier]) => `
      <div class="tier-block">
        <div class="tier-block-header">
          <span class="tier-block-name" style="color:${tier.color}">${tier.emoji} ${tier.name}</span>
          <span class="tier-block-sub">${tier.label}</span>
        </div>
        <div class="pills">
          ${tier.guns.map(g => `<span class="pill ${key}">${g}</span>`).join('')}
        </div>
      </div>`).join('');
  }

  renderBrowse();
  initStrip();
</script>

</body>
